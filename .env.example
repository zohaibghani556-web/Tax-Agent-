# TaxAgent.ai — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is listed in .gitignore.
#
# KEY ROTATION: Before going live, rotate all keys. See SECURITY-NOTES.md.
# GITHUB SECRET SCANNING: Enable in repo Settings → Security → Secret scanning.
# This file contains placeholder values only — never real credentials.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# Optional: enables multi-instance rate limiting via Upstash Redis sliding window.
# Without these, in-memory fallback is used (single-instance only — not suitable
# for scaled Vercel deployments). Get from console.upstash.com.
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Optional: error monitoring. Get from sentry.io.
# NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
