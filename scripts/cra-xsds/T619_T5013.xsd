			<xsd:element ref="T5013SlipAndSummary" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>

	<xsd:element name="T5013SlipAndSummary" type="T5013SlipSummaryType">
				<xsd:key name="Unique_T5013BN_Name">
					<xsd:selector xpath="T5013SummaryInformation"/>
					<xsd:field xpath="SummaryFilerAccountNumber"/>
				</xsd:key>
				<xsd:keyref name="Slip_T5013BN_Not_Equal_Summary_BN" refer="Unique_T5013BN_Name">
					<xsd:selector xpath="T5013SlipInformation"/>
					<xsd:field xpath="SlipFilerAccountNumber"/>
				</xsd:keyref>
	</xsd:element>

	<xsd:complexType name="T5013SlipSummaryType">
		<xsd:sequence>
			<xsd:element ref="T5013SlipInformation" minOccurs="0" maxOccurs="unbounded"/>
			<xsd:element ref="T5013SummaryInformation" minOccurs="1"/>
		</xsd:sequence>
	</xsd:complexType>

